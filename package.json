{
  "name": "aahi",
  "version": "0.2.2",
  "description": "Aahi — AI-native Software Operations Platform. The IDE that sees your living system.",
  "main": "dist/runtime/index.js",
  "scripts": {
    "build": "tsc -b runtime",
    "dev": "tsc -w -p tsconfig.json",
    "dev:runtime": "tsc -b runtime -w",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aahi-ide/aahi"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/ws": "^8.18.1",
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
