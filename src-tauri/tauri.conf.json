{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/tauri.conf.json",
  "productName": "Aahi",
  "version": "0.1.1",
  "identifier": "dev.aahi.app",
  "build": {
    "frontendDist": "../dist/ui",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui"
  },
  "app": {
    "windows": [
      {
        "title": "Aahi",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
